# JumpServer JIT Access Portal — Environment Configuration
# Copy this file to .env and fill in your values.

# JumpServer URL
JIT_JUMPSERVER_URL=https://jump.plano-wfm.cloud

# Private Token (generated via Django shell on JumpServer server)
JIT_JUMPSERVER_PRIVATE_TOKEN=your-private-token-here
JIT_JUMPSERVER_ORG_ID=00000000-0000-0000-0000-000000000002
JIT_JUMPSERVER_VERIFY_SSL=false

# Local DB path (container default uses ./data/jit_access.db)
JIT_DATABASE_URL=sqlite:///./jit_access.db

# JIT policy defaults
JIT_DEFAULT_ACCESS_DURATION_MINUTES=120
JIT_MAX_ACCESS_DURATION_MINUTES=480
JIT_AUTO_CLEANUP_INTERVAL_MINUTES=15

# Portal session signing key
JIT_SECRET_KEY=change-this-to-a-random-secret-key
JIT_SESSION_COOKIE_SECURE=false
JIT_SESSION_COOKIE_SAMESITE=lax

# Email notifications (optional)
JIT_SMTP_HOST=
JIT_SMTP_PORT=587
JIT_SMTP_USER=
JIT_SMTP_PASSWORD=
JIT_NOTIFICATION_FROM_EMAIL=
JIT_APPROVER_EMAILS=approver1@example.com,approver2@example.com
